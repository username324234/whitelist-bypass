{
  "name": "whitelist-bypass-creator",
  "version": "0.3.6",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc && electron .",
    "start:dev": "electron ."
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-fetch": "^2.6.13",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "whitelist.bypass.creator",
    "productName": "WhitelistBypass Creator",
    "directories": {
      "output": "../prebuilts"
    },
    "files": [
      "dist/**/*",
      "index.html",
      "styles/**/*",
      "scripts/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "../hooks/dc-creator-vk.js",
        "to": "hooks/dc-creator-vk.js"
      },
      {
        "from": "../hooks/video-vk.js",
        "to": "hooks/video-vk.js"
      },
      {
        "from": "../hooks/video-telemost.js",
        "to": "hooks/video-telemost.js"
      }
    ],
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns",
      "extraResources": [
        {
          "from": "../relay/relay-darwin",
          "to": "relay"
        },
        {
          "from": "../headless/headless-vk-darwin",
          "to": "headless-vk-creator"
        },
        {
          "from": "../headless/headless-telemost-darwin",
          "to": "headless-telemost-creator"
        },
        {
          "from": "../headless/headless-wbstream-darwin",
          "to": "headless-wbstream-creator"
        },
        {
          "from": "../headless/headless-dion-darwin",
          "to": "headless-dion-creator"
        }
      ]
    },
    "win": {
      "target": "portable",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "icon": "resources/icon.ico",
      "extraResources": [
        {
          "from": "../relay/relay-bundle.exe",
          "to": "relay.exe"
        },
        {
          "from": "../headless/headless-vk-bundle.exe",
          "to": "headless-vk-creator.exe"
        },
        {
          "from": "../headless/headless-telemost-bundle.exe",
          "to": "headless-telemost-creator.exe"
        },
        {
          "from": "../headless/headless-wbstream-bundle.exe",
          "to": "headless-wbstream-creator.exe"
        },
        {
          "from": "../headless/headless-dion-bundle.exe",
          "to": "headless-dion-creator.exe"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "icon": "resources/icon.png",
      "extraResources": [
        {
          "from": "../relay/relay-bundle",
          "to": "relay"
        },
        {
          "from": "../headless/headless-vk-bundle",
          "to": "headless-vk-creator"
        },
        {
          "from": "../headless/headless-telemost-bundle",
          "to": "headless-telemost-creator"
        },
        {
          "from": "../headless/headless-wbstream-bundle",
          "to": "headless-wbstream-creator"
        },
        {
          "from": "../headless/headless-dion-bundle",
          "to": "headless-dion-creator"
        }
      ]
    }
  }
}
