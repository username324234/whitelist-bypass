<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false"
    android:gravity="top"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp">

    <FrameLayout
        android:id="@+id/lineIconBox"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_settings_row_icon">

        <ImageView
            android:id="@+id/lineIcon"
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:layout_gravity="center"
            app:tint="@color/ink_2" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/lineMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:lineSpacingExtra="1dp"
            android:textColor="@color/ink"
            android:textIsSelectable="true"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/lineTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/ink_3"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/lineComp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_log_comp_chip"
                android:fontFamily="monospace"
                android:letterSpacing="0.16"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:textAllCaps="true"
                android:textColor="@color/ink_3"
                android:textSize="9sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
