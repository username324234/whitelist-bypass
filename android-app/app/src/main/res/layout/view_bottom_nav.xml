<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/hair" />

    <LinearLayout
        android:id="@+id/navItemsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:id="@+id/navMain"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_nav_item_active"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="6dp"
            android:paddingVertical="10dp">

            <ImageView
                android:id="@+id/navMainIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_main"
                app:tint="@color/accent_emerald" />

            <TextView
                android:id="@+id/navMainLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.14"
                android:textAllCaps="true"
                android:text="@string/nav_main"
                android:textColor="@color/accent_emerald"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="6dp"
            android:paddingVertical="10dp">

            <ImageView
                android:id="@+id/navSettingsIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_settings"
                app:tint="@color/ink_3" />

            <TextView
                android:id="@+id/navSettingsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.14"
                android:textAllCaps="true"
                android:text="@string/nav_settings"
                android:textColor="@color/ink_3"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navLogs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="6dp"
            android:paddingVertical="10dp">

            <ImageView
                android:id="@+id/navLogsIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_activity"
                app:tint="@color/ink_3" />

            <TextView
                android:id="@+id/navLogsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.14"
                android:textAllCaps="true"
                android:text="@string/nav_activity"
                android:textColor="@color/ink_3"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
