<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/hair" />

    <ScrollView
        android:id="@+id/overlayLogsScroll"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:overScrollMode="never"
        android:paddingHorizontal="14dp"
        android:paddingTop="8dp">

        <TextView
            android:id="@+id/overlayLogsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:lineSpacingExtra="1dp"
            android:textColor="@color/ink_2"
            android:textIsSelectable="true"
            android:textSize="10sp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="10dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/overlayCopyButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:minHeight="0dp"
            android:paddingHorizontal="10dp"
            android:text="@string/activity_copy"
            android:textColor="@color/ink"
            android:textSize="12sp"
            app:icon="@drawable/ic_action_copy"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconSize="14dp"
            app:iconTint="@color/ink" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/overlayShareButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:minHeight="0dp"
            android:paddingHorizontal="10dp"
            android:text="@string/activity_share"
            android:textColor="@color/ink"
            android:textSize="12sp"
            app:icon="@drawable/ic_action_share"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconSize="14dp"
            app:iconTint="@color/ink" />
    </LinearLayout>
</LinearLayout>
