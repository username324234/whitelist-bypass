<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:padding="8dp"
            android:src="@drawable/ic_chevron_left"
            app:tint="@color/ink" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/split_tunneling_title"
                android:textColor="@color/ink"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/splitSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:letterSpacing="0.14"
                android:textAllCaps="true"
                android:textColor="@color/ink_3"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/modeCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_stats_card"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/modeOff"
            style="@style/SplitModeRow">

            <TextView
                style="@style/SplitModeTitle"
                android:text="@string/split_tunneling_mode_off" />

            <ImageView
                android:id="@+id/modeOffCheck"
                style="@style/SplitModeCheck" />
        </LinearLayout>

        <View style="@style/StatHDivider" />

        <LinearLayout
            android:id="@+id/modeBypass"
            style="@style/SplitModeRow">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/SplitModeTitle"
                    android:text="@string/split_tunneling_mode_bypass" />

                <TextView
                    style="@style/SplitModeSub"
                    android:text="@string/split_tunneling_mode_bypass_sub" />
            </LinearLayout>

            <ImageView
                android:id="@+id/modeBypassCheck"
                style="@style/SplitModeCheck" />
        </LinearLayout>

        <View style="@style/StatHDivider" />

        <LinearLayout
            android:id="@+id/modeOnly"
            style="@style/SplitModeRow">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/SplitModeTitle"
                    android:text="@string/split_tunneling_mode_only" />

                <TextView
                    style="@style/SplitModeSub"
                    android:text="@string/split_tunneling_mode_only_sub" />
            </LinearLayout>

            <ImageView
                android:id="@+id/modeOnlyCheck"
                style="@style/SplitModeCheck" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/appsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:letterSpacing="0.18"
            android:textAllCaps="true"
            android:text="@string/split_tunneling_apps_section"
            android:textColor="@color/ink_3"
            android:textSize="10sp" />

        <CheckBox
            android:id="@+id/systemAppsCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/split_tunneling_show_system_apps"
            android:textColor="@color/ink_2"
            android:textSize="11sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/appsArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/loadingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />

        <LinearLayout
            android:id="@+id/appsListContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/searchInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_input"
                android:hint="@string/split_tunneling_search_apps_hint"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:padding="12dp"
                android:textColor="@color/ink"
                android:textColorHint="@color/ink_3"
                android:textSize="13sp" />

            <ListView
                android:id="@+id/appsListView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:choiceMode="multipleChoice"
                android:divider="@color/hair"
                android:dividerHeight="1dp" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
