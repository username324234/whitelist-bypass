<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/callRow"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_destination_card"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="14dp"
    android:paddingVertical="13dp">

    <View
        android:id="@+id/rowStatusDot"
        android:layout_width="9dp"
        android:layout_height="9dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_status_dot_idle" />

    <FrameLayout
        android:id="@+id/rowGlyphBox"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_glyph_chip">

        <TextView
            android:id="@+id/rowGlyph"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="monospace"
            android:textColor="@color/ink"
            android:textSize="12sp"
            android:textStyle="bold" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/rowName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/ink"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/rowLink"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:textColor="@color/ink_3"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
