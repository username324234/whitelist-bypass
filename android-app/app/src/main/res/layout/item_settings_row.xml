<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    tools:ignore="Overdraw"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="14dp"
    android:paddingVertical="12dp">

    <FrameLayout
        android:id="@+id/rowIconBox"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_settings_row_icon">

        <ImageView
            android:id="@+id/rowIcon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="center"
            app:tint="@color/ink_2" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/rowTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ink"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/rowSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/ink_3"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/rowTrail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:textColor="@color/ink_2"
        android:textSize="11sp"
        android:visibility="gone" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/rowSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:clickable="false"
        android:focusable="false"
        android:scaleX="0.85"
        android:scaleY="0.85"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/rowChev"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginStart="6dp"
        android:src="@drawable/ic_chevron_right"
        app:tint="@color/ink_3"
        android:visibility="gone" />
</LinearLayout>
