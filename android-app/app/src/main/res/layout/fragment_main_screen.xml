<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/headerSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.14"
                    android:textAllCaps="true"
                    android:text="@string/main_sub_no_configs"
                    android:textColor="@color/ink_3"
                    android:textSize="10sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/headerAddButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_button"
                android:contentDescription="@string/picker_add_title"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_plus"
                app:tint="@color/ink_2" />
        </LinearLayout>


        <FrameLayout
            android:layout_width="248dp"
            android:layout_height="248dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp">

            <bypass.whitelist.ui.HeroRingOuterView
                android:id="@+id/heroRingOuter"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <View
                android:id="@+id/heroRingMid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="14dp"
                android:background="@drawable/bg_hero_ring_dashed" />

            <View
                android:id="@+id/heroRingInner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="28dp"
                android:background="@drawable/bg_hero_inner" />

            <View
                android:id="@+id/heroPulse"
                android:layout_width="168dp"
                android:layout_height="168dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_hero_pulse"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/heroButton"
                android:layout_width="168dp"
                android:layout_height="168dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_hero_idle"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/heroPowerIcon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="40dp"
                    android:src="@drawable/ic_power"
                    app:tint="@color/ink_3" />

                <TextView
                    android:id="@+id/heroLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="98dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.22"
                    android:textAllCaps="true"
                    android:text="@string/hero_connect"
                    android:textColor="@color/ink_3"
                    android:textSize="11sp" />
            </FrameLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/statusHeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="22dp"
            android:text="@string/status_headline_disconnected"
            android:textColor="@color/ink"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/statusDot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_status_dot_idle" />

            <TextView
                android:id="@+id/statusDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text=""
                android:textColor="@color/ink_3"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/callsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/emptyCta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_destination_card_empty"
            android:baselineAligned="false"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_empty_cta_plus">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_plus"
                    app:tint="@color/accent_emerald" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/empty_calls_title"
                    android:textColor="@color/accent_emerald"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="monospace"
                    android:text="@string/empty_calls_sub"
                    android:textColor="@color/ink_3"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/statsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_stats_card"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:visibility="gone">

            <LinearLayout
                style="@style/StatCell"
                android:layout_width="0dp"
                android:layout_weight="1">

                <TextView style="@style/StatLabel" android:text="@string/stat_uptime" />
                <TextView android:id="@+id/statUptime" style="@style/StatValue" tools:text="00:00:00" />
            </LinearLayout>

            <View style="@style/StatVDivider" />

            <LinearLayout
                style="@style/StatCell"
                android:layout_width="0dp"
                android:layout_weight="1">

                <TextView style="@style/StatLabel" android:text="@string/stat_mode" />
                <TextView android:id="@+id/statMode" style="@style/StatValue" tools:text="--" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/pingRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/pingButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_ping_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_radar"
                    app:tint="@color/ink" />

                <TextView
                    android:id="@+id/pingButtonLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ping_run"
                    android:textColor="@color/ink"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/pingResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_ping_result_ok"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/pingResultHost"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:text=""
                    android:textColor="@color/accent_emerald"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/pingResultRtt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text=""
                    android:textColor="@color/accent_emerald"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
